with "config/reinforcement_learning_tests_config.gpr";
project Reinforcement_Learning_Tests is

   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & Reinforcement_Learning_Tests_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("reinforcement_learning_tests.adb");

   package Compiler is
      for Default_Switches ("Ada") use Reinforcement_Learning_Tests_Config.Ada_Compiler_Switches;
      -- for Default_Switches ("Ada") use (
      --    "-g" -- , "-gnatQ", "-O1", "-gnatf", "-gnato",
      --    -- "-gnatwa.Xe", "-gnaty", "-gnat12"
      -- );
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Reinforcement_Learning_Tests;
